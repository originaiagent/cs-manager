# Core API
CORE_API_URL=https://origin-core-465031496778.asia-northeast1.run.app
INTERNAL_API_KEY=your-internal-api-key

# AI API
ORIGIN_AI_URL=https://origin-ai-five.vercel.app
ORIGIN_AI_API_KEY=your-origin-ai-api-key
ORIGIN_AI_TOOL_NAME=cs-manager

# embed 読み書き自動化 (write handshake + 入口)
# ORIGIN_AI_BASE_URL: embed run / MCP validate / audit の宛先 (origin-ai base)。
ORIGIN_AI_BASE_URL=https://origin-ai-five.vercel.app
# EMBED_CLIENT_KEY: per-tool embed key (X-Embed-Key)。**サーバ側のみ・ブラウザ非露出**。
#   入口 /api/embed-run が origin-ai /api/embed/run へ送出する。未配布時 503 (ボタン無効)。
EMBED_CLIENT_KEY=your-embed-client-key
# EMBED_REVERSIBILITY_ENABLED: MCP write の可逆ハンドシェイクを有効化 (既存窓口)。
EMBED_REVERSIBILITY_ENABLED=true
# EMBED_MCP_VALIDATE_KEY: origin-ai validate/audit コールバック認証鍵 (未設定時 INTERNAL_API_KEY)。
# EMBED_MCP_VALIDATE_KEY=

# RAG (Stage2) — origin-ai RAG skill 連携
# 認証鍵は Core 経由で動的解決するため env に鍵は持たない (B案)。
# RAG_INTERNAL_CRED_SERVICE_CODE: origin-ai rag endpoint 認証用 credential の service_code (既定 origin_ai_internal)
RAG_INTERNAL_CRED_SERVICE_CODE=origin_ai_internal
# RAG_FILTER_VISIBILITY: hybrid-search の visibility 許可 (カンマ区切り、既定 public,internal)
RAG_FILTER_VISIBILITY=public,internal
# RAG_TIMEOUT_MS: RAG skill 呼び出しタイムアウト (既定 60000)
RAG_TIMEOUT_MS=60000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ユーザー認証 (Core を IdP とする Third-Party Auth / JWKS)
# OFF 既定。ON にする前に cs-manager Supabase に JWKS provider 登録が必須 (未登録で ON は全員ロックアウト)。
NEXT_PUBLIC_CORE_AUTH_ENABLED=false
# origin-core 側 Supabase (ユーザーのマスタ / JWT 発行元)
NEXT_PUBLIC_CORE_SUPABASE_URL=https://<core-project-ref>.supabase.co
NEXT_PUBLIC_CORE_SUPABASE_ANON_KEY=your-core-supabase-anon-key
