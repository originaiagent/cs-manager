{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/block-dangerous-git.sh'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/protect-sensitive-files.sh'"
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/pre-pr-quality-check.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/stop-test-gate.sh'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/policy_gate_stop.sh'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/report_package_validator.sh'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/user/repos/cs-manager/.codex/hooks/question_classifier.sh'"
          }
        ]
      }
    ]
  }
}
